POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DB_URL=postgresql+psycopg://postgres:postgres@postgres:5432/flow

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback

SECRET_KEY=replace-with-secure-random
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]

# Локально: http://localhost:8000
# За nginx на VPS (один origin): оставь пустым
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
ADMIN_EMAIL=admin@example.com

# Опционально: отправка кода подтверждения по почте.
#
# Вариант A — VPS (Timeweb): Resend API через HTTPS:443 (SMTP на VPS часто заблокирован)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=onboarding@resend.dev
#
# Вариант B — локально: Gmail SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_USE_TLS=true
#
# Если ни Resend, ни SMTP — код пишется в лог backend.
